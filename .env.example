# Public URL where the browser accesses Hotfix.
# This must match the origin you use in the OAuth app callback configuration.
HOTFIX_PUBLIC_URL=http://localhost:5173

# Address the Rust backend binds to locally.
HOTFIX_LISTEN_ADDR=127.0.0.1:3000

# PostgreSQL connection string used by the Rust backend for users and session storage.
HOTFIX_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/hotfix

# Base64-encoded secret used to encrypt and sign session cookies.
# Generate one with: openssl rand -base64 32
HOTFIX_SESSION_SECRET=replace-with-openssl-rand-base64-32

# GitHub OAuth app client ID for the "Continue with GitHub" button.
HOTFIX_GITHUB_CLIENT_ID=replace-me

# GitHub OAuth app client secret paired with HOTFIX_GITHUB_CLIENT_ID.
HOTFIX_GITHUB_CLIENT_SECRET=replace-me

# Sentry OAuth app client ID for the "Continue with Sentry" button.
HOTFIX_SENTRY_CLIENT_ID=replace-me

# Sentry OAuth app client secret paired with HOTFIX_SENTRY_CLIENT_ID.
HOTFIX_SENTRY_CLIENT_SECRET=replace-me

# Optional filesystem cache directory for immutable repo snapshot archives.
# Defaults to the OS temp directory when omitted.
HOTFIX_SNAPSHOT_CACHE_DIR=

# Runtime mode for the backend binary.
# Use `api` for the main app and `mock_sandbox` to run the local sandbox server.
HOTFIX_RUN_MODE=api

# Base URL for the sandbox provider the API backend dispatches index jobs to.
# In local development this should point at the mock sandbox server.
HOTFIX_SANDBOX_URL=http://127.0.0.1:4001

# Address the local mock sandbox server binds to when HOTFIX_RUN_MODE=mock_sandbox.
HOTFIX_MOCK_SANDBOX_LISTEN_ADDR=127.0.0.1:4001

# How frequently the API backend polls Postgres for queued indexing jobs.
HOTFIX_INDEX_JOB_POLL_INTERVAL_MS=1500

# Optional GitHub webhook secret used to validate push events for branch reindexing.
HOTFIX_GITHUB_WEBHOOK_SECRET=

# Backend URL the Solid dev server proxies /api requests to in development.
# Leave this at the default unless your Rust backend runs on a different address.
VITE_API_PROXY_TARGET=http://127.0.0.1:3000
